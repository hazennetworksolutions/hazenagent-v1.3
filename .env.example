# ===================================
# HAZENAGENT - PREMIUM 4 MODEL SYSTEM
# (gpt-4o removed due to poor quality)
# ===================================

# ============================================
# AI MODEL PROVIDERS (At least ONE required)
# ============================================

# Anthropic (DEFAULT PROVIDER - CODE CHAMPION!)
# Models: claude-sonnet-4-5-20250929, claude-haiku-4-5-20251001
# URL: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI (MAXIMUM QUALITY ONLY)
# Models: gpt-5-pro (gpt-4o removed - poor quality)
# URL: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxx

# Google Gemini (RESEARCH CHAMPION)
# Models: gemini-3-pro-preview
# URL: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaxxxxx

# ============================================
# MODEL CONFIGURATION
# ============================================

# Default Provider (anthropic, openai, or google)
LLM_PROVIDER=anthropic

# Default Model (for complex tasks)
# Options: claude-sonnet-4-5-20250929, gpt-5-pro, gemini-3-pro-preview
DEFAULT_MODEL=claude-sonnet-4-5-20250929

# Fast Model (for quick responses)
# Options: claude-haiku-4-5-20251001, gpt-5-pro, gemini-3-pro-preview
FAST_MODEL=claude-haiku-4-5-20251001

# Enable Hybrid Model System (auto task-based routing)
ENABLE_HYBRID_MODELS=true

# ============================================
# PREMIUM 4 MODEL SYSTEM (gpt-4o REMOVED)
# ============================================
# Active Models:
#   1. gpt-5-pro (Maximum Quality) - $10/$40
#   2. claude-sonnet-4-5-20250929 (Code Champion) - $3/$15
#   3. claude-haiku-4-5-20251001 (Fast Path) - $0.80/$4
#   4. gemini-3-pro-preview (Research Champion) - $1.25/$5
#
# Removed: gpt-4o (poor quality responses)
# ============================================

# ============================================
# SERVER CONFIGURATION
# ============================================

# API Server Host
HOST=0.0.0.0

# API Server Port
PORT=8000

# Server Name
SERVER_NAME=HazenAgent

# Environment (development, production)
ENVIRONMENT=production

# ============================================
# OPTIONAL: ADDITIONAL SERVICES
# ============================================

# LangSmith (for LangGraph monitoring)
LANGSMITH_API_KEY=

# News API (for news search)
NEWS_API_KEY=

# Serper API (for web search)
SERPER_API_KEY=

# ============================================
# DEPLOYMENT SETTINGS
# ============================================

# Agent Timeout (seconds)
AGENT_TIMEOUT=60

# Max Retries
MAX_RETRIES=3

# Cache TTL (seconds)
CACHE_TTL=3600

# Enable Debug Mode
DEBUG=false

# Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ============================================
# WARDEN PROTOCOL INTEGRATION
# ============================================

# Assistant ID (fixed for Warden compliance)
ASSISTANT_ID=hazenagent-warden-001

# Enable A2A (Agent-to-Agent) Protocol
ENABLE_A2A=true

# LangGraph Cloud API Compatibility
LANGGRAPH_API_COMPATIBLE=true

# ============================================
# HOW TO USE
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and add your API keys
# 3. At least ONE provider (Anthropic, OpenAI, or Google) is required
# 4. Start agent: langgraph up OR python -m src.api
# ============================================
